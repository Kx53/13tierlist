---
import CreateForm from "@/components/CreateForm";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Create Tier List — 13TierList"
  description="Create a new image-based tier list"
>
  <div class="mx-auto max-w-3xl py-14 sm:py-20">
    <div class="mb-10 text-center">
      <p class="text-xs uppercase tracking-[0.28em] text-brand-200/85">Start Fresh</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">
        Create a New Tier List
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-base leading-7 text-muted-foreground">
        Give your tier list a name and start ranking!
      </p>
    </div>

    <div class="surface-shell p-6 sm:p-8">
      <CreateForm client:load />
    </div>
  </div>
</Layout>

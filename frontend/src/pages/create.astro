---
import Layout from '../layouts/Layout.astro';
import CreateForm from '../components/CreateForm';
---

<Layout title="Create Tier List — 13TierList" description="Create a new image-based tier list">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="text-center mb-12 animate-fade-in">
      <h1 class="text-3xl sm:text-4xl font-bold text-surface-100">
        Create a New Tier List
      </h1>
      <p class="mt-3 text-surface-400">
        Give your tier list a name and start ranking!
      </p>
    </div>

    <div class="card animate-slide-up">
      <CreateForm client:load />
    </div>
  </div>
</Layout>

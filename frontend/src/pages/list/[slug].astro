---
import TierListApp from "@/components/TierListApp";
import Layout from "@/layouts/Layout.astro";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/");
}
---

<Layout title="Tier List — 13TierList" description="View and edit this tier list">
  <div class="mx-auto max-w-[88rem] py-4 sm:py-8">
    <TierListApp client:load slug={slug} />
  </div>
</Layout>

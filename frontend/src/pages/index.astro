---
import Layout from '../layouts/Layout.astro';
---

<Layout title="13TierList — Create & Share Tier Lists" description="Create beautiful image-based tier lists and share them with anyone">
  <div class="relative overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s"></div>
    </div>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 text-center">
      <div class="animate-fade-in">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent-500/10 border border-accent-500/20 text-accent-400 text-sm font-medium mb-8">
          🎮 Free · No signup · Instant sharing
        </span>
      </div>

      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-tight animate-slide-up">
        <span class="bg-gradient-to-r from-white via-surface-200 to-surface-400 bg-clip-text text-transparent">
          Rank Everything
        </span>
        <br />
        <span class="bg-gradient-to-r from-accent-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
          Your Way
        </span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-surface-400 max-w-2xl mx-auto animate-slide-up" style="animation-delay: 0.1s">
        Create stunning image-based tier lists, drag & drop to rank, and share with anyone — no account needed.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.2s">
        <a href="/create" class="btn-primary text-base px-8 py-3.5 rounded-2xl shadow-2xl shadow-accent-500/20
                                  hover:shadow-accent-500/40 hover:-translate-y-0.5 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
          </svg>
          Create Tier List
        </a>
      </div>
    </section>

    <!-- Features -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="card hover:border-accent-500/30 hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl bg-accent-500/10 flex items-center justify-center text-2xl mb-4
                      group-hover:scale-110 transition-transform duration-300">
            🖱️
          </div>
          <h3 class="text-lg font-semibold text-surface-100 mb-2">Drag & Drop</h3>
          <p class="text-surface-400 text-sm">Intuitively rank items by dragging them between tiers. Reorder within tiers too.</p>
        </div>

        <div class="card hover:border-purple-500/30 hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-2xl mb-4
                      group-hover:scale-110 transition-transform duration-300">
            🔗
          </div>
          <h3 class="text-lg font-semibold text-surface-100 mb-2">Instant Sharing</h3>
          <p class="text-surface-400 text-sm">Get a shareable link immediately. No login required — share with anyone.</p>
        </div>

        <div class="card hover:border-pink-500/30 hover:-translate-y-1 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center text-2xl mb-4
                      group-hover:scale-110 transition-transform duration-300">
            🖼️
          </div>
          <h3 class="text-lg font-semibold text-surface-100 mb-2">Image-Based</h3>
          <p class="text-surface-400 text-sm">Add images via URL to create visual tier lists for games, anime, food, and more.</p>
        </div>
      </div>
    </section>
  </div>
</Layout>

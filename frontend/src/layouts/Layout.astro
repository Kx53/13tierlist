---
import "@/styles/global.css";
import { Trophy } from "lucide-react";
import FooterText from "@/components/FooterText";
import LanguagePicker from "@/components/LanguagePicker";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "13TierList",
  description = "Create and share tier lists with friends. — tierlist.13room.space",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#060816" />
    <meta name="theme-color" content="#060816" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&family=Sarabun:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <nav class="sticky top-0 z-50 border-b border-border/60 bg-background/72 backdrop-blur-xl">
      <div class="mx-auto flex h-18 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="group flex items-center gap-3">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-border/70 bg-secondary/75 shadow-[0_18px_44px_-28px_rgba(118,225,255,0.8)]">
            <Trophy className="h-5 w-5 text-brand-400" />
          </div>
          <span class="text-sm font-semibold uppercase tracking-[0.28em] text-gradient-brand sm:text-base">
            13TierList
          </span>
        </a>

        <div class="flex items-center gap-4">
          <LanguagePicker client:load />
          <a
            href="/create"
            class="inline-flex h-10 items-center justify-center rounded-full border border-border bg-primary px-4 text-sm font-medium text-primary-foreground shadow-[0_16px_40px_-20px_rgba(76,92,255,0.95)] transition-all hover:bg-primary/92"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="mr-2 h-4 w-4"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                clip-rule="evenodd"
              />
            </svg>
            Create
          </a>
        </div>
      </div>
    </nav>

    <main class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>

    <footer class="mt-auto border-t border-border/60">
      <div class="mx-auto max-w-7xl px-4 py-8 text-center text-sm text-muted-foreground sm:px-6 lg:px-8">
        <FooterText client:load /> &middot; 13TierList by 13room.space
      </div>
    </footer>
  </body>
</html>
